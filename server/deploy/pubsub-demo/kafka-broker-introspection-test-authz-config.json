{
  "allowRemoteResourceManagement": true,
  "policyEnforcementMode": "ENFORCING",
  "resources": [
    {
      "name": "kafka-cluster:foobarbaz,Topic:*",
      "type": "Topic",
      "ownerManagedAccess": false,
      "displayName": "Every topic",
      "attributes": {},
      "uris": [],
      "scopes": [
        {
          "name": "Describe"
        },
        {
          "name": "Write"
        },
        {
          "name": "Create"
        },
        {
          "name": "Delete"
        },
        {
          "name": "IdempotentWrite"
        },
        {
          "name": "Read"
        },
        {
          "name": "DescribeConfigs"
        },
        {
          "name": "AlterConfigs"
        }
      ],
      "icon_uri": ""
    },
    {
      "name": "Cluster:*",
      "type": "Cluster",
      "ownerManagedAccess": false,
      "displayName": "Demo cluster",
      "attributes": {},
      "uris": [],
      "scopes": [
        {
          "name": "Describe"
        },
        {
          "name": "Create"
        },
        {
          "name": "IdempotentWrite"
        },
        {
          "name": "Alter"
        },
        {
          "name": "DescribeConfigs"
        },
        {
          "name": "AlterConfigs"
        },
        {
          "name": "ClusterAction"
        }
      ],
      "icon_uri": ""
    }
  ],
  "policies": [
    {
      "name": "Topics-ro",
      "description": "A policy for the that ties test-client to read only access to devices' topics",
      "type": "client",
      "logic": "POSITIVE",
      "decisionStrategy": "UNANIMOUS",
      "config": {
        "clients": "[\"test-client\"]"
      }
    },
    {
      "name": "Cluster-administration",
      "description": "A policy allowing for basic administration of a Kafka cluster",
      "type": "client",
      "logic": "POSITIVE",
      "decisionStrategy": "UNANIMOUS",
      "config": {
        "clients": "[\"rdfm-management-server-cluster-admin\"]"
      }
    },
    {
      "name": "ro-every-topic",
      "description": "Grants read access to every topic",
      "type": "scope",
      "logic": "POSITIVE",
      "decisionStrategy": "UNANIMOUS",
      "config": {
        "resources": "[\"kafka-cluster:foobarbaz,Topic:*\"]",
        "scopes": "[\"Describe\",\"Read\"]",
        "applyPolicies": "[\"Topics-ro\"]"
      }
    },
    {
      "name": "admin-cluster",
      "description": "Grants a subset of administrative rights to the cluster",
      "type": "scope",
      "logic": "POSITIVE",
      "decisionStrategy": "UNANIMOUS",
      "config": {
        "resources": "[\"Cluster:*\"]",
        "scopes": "[\"Alter\",\"Describe\"]",
        "applyPolicies": "[\"Cluster-administration\"]"
      }
    },
    {
      "name": "admin-every-topic",
      "description": "Grants a subset of administrative rights to every topic",
      "type": "scope",
      "logic": "POSITIVE",
      "decisionStrategy": "UNANIMOUS",
      "config": {
        "resources": "[\"kafka-cluster:foobarbaz,Topic:*\"]",
        "scopes": "[\"Describe\",\"Create\"]",
        "applyPolicies": "[\"Cluster-administration\"]"
      }
    }
  ],
  "scopes": [
    {
      "name": "Create"
    },
    {
      "name": "Read"
    },
    {
      "name": "Write"
    },
    {
      "name": "Delete"
    },
    {
      "name": "Alter"
    },
    {
      "name": "Describe"
    },
    {
      "name": "ClusterAction"
    },
    {
      "name": "DescribeConfigs"
    },
    {
      "name": "AlterConfigs"
    },
    {
      "name": "IdempotentWrite"
    }
  ],
  "decisionStrategy": "AFFIRMATIVE"
}
